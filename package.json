{
  "name": "website-bot",
  "version": "2.0.0",
  "description": "L9 Website Factory — multi-stage pipeline, SEO-Bot parity build",
  "type": "module",
  "scripts": {
    "pipeline": "npx tsx scripts/run-pipeline.ts",
    "pipeline:dry": "npx tsx scripts/run-pipeline.ts --dry-run --spec=fixtures/ci-test-spec.yaml",
    "typecheck": "tsc --noEmit",
    "normalize-spec": "npx tsx scripts/normalize-spec.ts",
    "normalize-spec:check": "npx tsx scripts/normalize-spec.ts --check",
    "validate": "node scripts/verify-launch-env.mjs"
  },
  "dependencies": {
    "@quantum-l9/llm-router": "^1.0.0",
    "better-sqlite3": "^9.4.3",
    "drizzle-orm": "^0.30.10",
    "pino": "^9.1.0",
    "yaml": "^2.4.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.0.0",
    "pino-pretty": "^11.0.0",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  },
  "engines": { "node": ">=20.0.0" }
}
