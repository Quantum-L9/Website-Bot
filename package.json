{
  "name": "l9-website-factory",
  "version": "2.0.0",
  "description": "L9 Website Factory Bot - deterministic website generation pipeline with @l9/llm-router integration",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/llm-router"
  ],
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "verify:preflight": "node scripts/preflight.mjs",
    "verify:source": "node scripts/verify-source.mjs",
    "verify:build": "node scripts/verify-build.mjs",
    "verify:smoke": "node scripts/verify-smoke.mjs",
    "verify:form": "node scripts/verify-form.mjs",
    "verify:analytics": "node scripts/verify-analytics.mjs",
    "verify:crm": "node scripts/verify-crm.mjs",
    "verify:seo": "node scripts/verify-seo.mjs",
    "verify:rollback": "node scripts/verify-rollback.mjs",
    "verify:all": "node scripts/verify-all.mjs",
    "deploy:preview": "node scripts/deploy.mjs --preview",
    "deploy:production": "node scripts/deploy.mjs --prod",
    "verify:launch-env": "node scripts/verify-launch-env.mjs",
    "verify:visual-qa": "node scripts/verify-visual-qa.mjs",
    "build:router": "cd packages/llm-router && npx tsc",
    "generate:domain-spec": "npx tsx src/services/generate-domain-spec.ts",
    "generate:content": "npx tsx src/services/generate-content.ts"
  },
  "dependencies": {
    "@astrojs/sitemap": "latest",
    "@esbuild/linux-x64": "^0.25.12",
    "@l9/llm-router": "workspace:*",
    "astro": "latest"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
