---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadForm from '../components/LeadForm.astro';
---
<BaseLayout title="Insurance Supplementing | Supplemental Insurance Pros" description="Insurance claim supplement support for property estimates and documentation.">
<section class="hero"><div class="container"><p class="eyebrow">Insurance Supplementing</p><h1>Claim supplement support that starts with scope and documentation.</h1><p>A supplement is a documented request for additional covered scope or cost items that may not have been included in the original estimate.</p><a class="btn" href="/contact">Upload Your Estimate</a></div></section><section><div class="container grid two"><div class="card"><h2>What we review</h2><p>Original estimates, repair scope, missing line items, photos, carrier notes, and supporting documentation.</p></div><div class="card"><h2>What we do not promise</h2><p>We do not guarantee approval, payment, or carrier outcome.</p></div></div></section><section><div class="container"><h2>Documents that help</h2><ul><li>Carrier estimate</li><li>Contractor estimate</li><li>Photos</li><li>Claim correspondence</li><li>Damage notes</li></ul></div></section>
</BaseLayout>
