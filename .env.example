# L9 Website Factory Environment Variables

# ═══════════════════════════════════════════════════════════════
# @quantum-l9/llm-router Configuration
# ═══════════════════════════════════════════════════════════════
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
CLIENT_ID=your-client-domain
MONTHLY_BUDGET_PER_CLIENT=200
WEEKLY_BUDGET_TARGET=50
SITE_URL=http://localhost:4321

# ═══════════════════════════════════════════════════════════════
# Deployment
# ═══════════════════════════════════════════════════════════════
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# ═══════════════════════════════════════════════════════════════
# Launch gate (see config/launch-env.required.yaml — verified by
# scripts/verify-launch-env.mjs; production fails closed until satisfied)
# ═══════════════════════════════════════════════════════════════
# Project / support / security
PROJECT_LICENSE=
LICENSE_CHOICE_REQUIRED=true
SUPPORT_CONTACT_EMAIL=
SUPPORT_CONTACT_URL=
SECURITY_CONTACT_EMAIL=
SECURITY_DISCLOSURE_URL=

# Domain
PUBLIC_SITE_URL=
PRODUCTION_DOMAIN=
DOMAIN_VERIFICATION_REQUIRED=true

# Lead form
FORM_PROVIDER=
FORM_ENDPOINT_URL=
FORM_WEBHOOK_SECRET=
LEAD_NOTIFICATION_EMAIL=

# Analytics
ANALYTICS_PROVIDER=
ANALYTICS_MEASUREMENT_ID=
ANALYTICS_CONVERSION_EVENT=
ANALYTICS_THANK_YOU_EVENT=

# Legal
LEGAL_DISCLAIMER_APPROVED=false
LEGAL_DISCLAIMER_VERSION=
LEGAL_REVIEW_OWNER=

# Professional license — only when the client's vertical requires displaying one
LICENSE_DISPLAY_REQUIRED=false
PROFESSIONAL_LICENSE_NUMBER=
PROFESSIONAL_LICENSE_STATE=
PROFESSIONAL_LICENSE_TYPE=

# CRM provider (e.g. acculynx, hubspot, salesforce, none)
CRM_PROVIDER=
CRM_API_BASE_URL=
CRM_CLIENT_ID=
CRM_CLIENT_SECRET=
CRM_API_TOKEN=
CRM_TEST_MODE=true
