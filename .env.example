# L9_META: layer=configuration, role=tracked_file, status=active, version=1.0.0
# L9 Website Factory Environment Variables

# @quantum-l9/llm-router
PERPLEXITY_API_KEY=
OPENROUTER_API_KEY=
CLIENT_ID=your-client-domain
MONTHLY_BUDGET_PER_CLIENT=200
WEEKLY_BUDGET_TARGET=50
SITE_URL=https://your-client-domain.example

# Site-factory execution mode and local proof
SITE_OUTPUT_DIR=
SITE_BUILD_TIMEOUT_MS=900000
SITE_BUILD_IGNORE_SCRIPTS=false
ASTRO_TELEMETRY_DISABLED=1

# Per-client GitHub source publication. Prefer DomainSpec.deploy values for
# target identity; tokens remain runtime-only.
CLIENT_GITHUB_REPO=owner/disposable-or-client-site
CLIENT_GITHUB_REPO_ID=
CLIENT_SOURCE_BRANCH=main
GITHUB_SITE_TOKEN=

# Per-client Vercel deployment
CLIENT_VERCEL_PROJECT_ID=
CLIENT_VERCEL_DEPLOY_HOOK=
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_TARGET=preview
WEBSITE_BOT_ALLOW_PRODUCTION=false
VERCEL_POLL_INTERVAL_MS=10000
VERCEL_MAX_POLLS=60

# Legacy shared deployment values retained only for migration visibility. The
# site-factory spine does not consume these because one shared project/repo can
# overwrite another client's site.
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# PostHog public project key used in generated browser source. Never place a
# PostHog personal API token here.
PUBLIC_POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PROJECT_ID=
POSTHOG_PERSONAL_API_KEY=

# SEO baseline and handoff
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
SEO_BOT_URL=
SEO_BOT_API_KEY=

# Launch gate: project / support / security
PROJECT_LICENSE=
LICENSE_CHOICE_REQUIRED=true
SUPPORT_CONTACT_EMAIL=
SUPPORT_CONTACT_URL=
SECURITY_CONTACT_EMAIL=
SECURITY_DISCLOSURE_URL=

# Domain
PUBLIC_SITE_URL=
PRODUCTION_DOMAIN=
DOMAIN_VERIFICATION_REQUIRED=true

# Lead form
FORM_PROVIDER=
FORM_ENDPOINT_URL=
FORM_WEBHOOK_SECRET=
LEAD_NOTIFICATION_EMAIL=

# Analytics launch contract
ANALYTICS_PROVIDER=
ANALYTICS_MEASUREMENT_ID=
ANALYTICS_CONVERSION_EVENT=
ANALYTICS_THANK_YOU_EVENT=

# Legal
LEGAL_DISCLAIMER_APPROVED=false
LEGAL_DISCLAIMER_VERSION=
LEGAL_REVIEW_OWNER=

# Professional license, only when the client's vertical requires display
LICENSE_DISPLAY_REQUIRED=false
PROFESSIONAL_LICENSE_NUMBER=
PROFESSIONAL_LICENSE_STATE=
PROFESSIONAL_LICENSE_TYPE=

# CRM provider: acculynx, hubspot, salesforce, none, or another configured adapter
CRM_PROVIDER=
CRM_API_BASE_URL=
CRM_CLIENT_ID=
CRM_CLIENT_SECRET=
CRM_API_TOKEN=
CRM_TEST_MODE=true

# Automatic client provisioning (P-F)
# GITHUB_PROVISION_TOKEN creates/adopts client repositories. Keep it separate
# from the narrower publication and SEO maintenance credentials.
GITHUB_PROVISION_TOKEN=
# The existing GITHUB_SITE_TOKEN above is referenced by env://GITHUB_SITE_TOKEN.
# Referenced by env://SEO_BOT_SITE_GITHUB_TOKEN in the v3 maintenance handoff.
SEO_BOT_SITE_GITHUB_TOKEN=
# Optional. Git-linked Vercel projects deploy on push without this hook.
SEO_BOT_SITE_VERCEL_DEPLOY_HOOK=
