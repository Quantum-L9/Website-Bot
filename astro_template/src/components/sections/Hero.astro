<!-- L9_META: layer=template, role=hero_section, status=active, version=1.0.0 -->
---
interface Props { name?: string; content: string; }
const { name = 'hero', content } = Astro.props;
const paragraphs = content.split(/\n{2,}/).map(value => value.trim()).filter(Boolean);
---
<section class="hero" data-section={name}>
  <h1>{paragraphs[0] ?? 'Welcome'}</h1>
  {paragraphs.map(paragraph => <p>{paragraph}</p>)}
</section>
