<!-- L9_META: layer=template, role=compliance_section, status=active, version=1.0.0 -->
---
interface Props { name?: string; content: string; }
const { name = 'compliance_note', content } = Astro.props;
const paragraphs = content.split(/\n{2,}/).map(value => value.trim()).filter(Boolean);
---
<section class="notice" data-section={name}>
  <h2>Important information</h2>
  {paragraphs.map(paragraph => <p>{paragraph}</p>)}
</section>
