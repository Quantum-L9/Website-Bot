<!-- L9_META: layer=template, role=generic_section, status=active, version=1.0.0 -->
---
interface Props { name?: string; content: string; }
const { name = 'section', content } = Astro.props;
const paragraphs = content.split(/\n{2,}/).map(value => value.trim()).filter(Boolean);
---
<section class="prose" data-section={name}>
  <h2>{name.replaceAll('_', ' ').replace(/\b\w/g, character => character.toUpperCase())}</h2>
  {paragraphs.map(paragraph => <p>{paragraph}</p>)}
</section>
