<!-- L9_META: layer=template, role=cta_section, status=active, version=1.0.0 -->
---
interface Props { name?: string; content: string; }
const { name = 'cta', content } = Astro.props;
const paragraphs = content.split(/\n{2,}/).map(value => value.trim()).filter(Boolean);
---
<section class="cta-banner" data-section={name}>
  <h2>Take the next step</h2>
  {paragraphs.map(paragraph => <p>{paragraph}</p>)}
</section>
