<!-- L9_META: layer=template, role=audience_paths_section, status=active, version=1.0.0 -->
---
interface Props { name?: string; content: string; }
const { name = 'audience_paths', content } = Astro.props;
const paragraphs = content.split(/\n{2,}/).map(value => value.trim()).filter(Boolean);
---
<section class="grid two" data-section={name}>
  <h2>Choose your path</h2>
  {paragraphs.map(paragraph => <p>{paragraph}</p>)}
</section>
