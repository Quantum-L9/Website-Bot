{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:quantum-l9:website-bot:stage-checkpoint:v2",
  "title": "Website-Bot Stage Checkpoint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "build_id",
    "client_id",
    "stage",
    "attempt",
    "input_evidence",
    "output_evidence",
    "input_digest",
    "output_digest",
    "status",
    "started_at",
    "completed_at"
  ],
  "properties": {
    "schema": {
      "const": "website-bot.stage-checkpoint/v2"
    },
    "build_id": {
      "type": "string",
      "minLength": 1
    },
    "client_id": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "type": "string",
      "minLength": 1
    },
    "stage_version": {
      "type": "string",
      "minLength": 1
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "input_evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      }
    },
    "output_evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      }
    },
    "input_digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "output_digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "external_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "passed",
        "failed"
      ]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "schema",
        "logical_id",
        "relative_path",
        "sha256"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "assembly",
            "build",
            "publication",
            "deployment",
            "release",
            "handoff",
            "registration_ack",
            "failure"
          ]
        },
        "schema": {
          "type": "string",
          "minLength": 1
        },
        "logical_id": {
          "type": "string",
          "minLength": 1
        },
        "relative_path": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "(^/|(^|/)\\.\\.(/|$))"
          }
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    }
  },
  "x_l9_meta": {
    "layer": "contract",
    "role": "persisted_schema",
    "status": "active",
    "version": "2.0.0"
  }
}
