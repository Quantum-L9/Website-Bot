{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:quantum-l9:website-bot:assembly-manifest:v2",
  "title": "Website-Bot Assembly Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "build_id",
    "client_id",
    "generator_version",
    "template_version",
    "template_digest",
    "routes",
    "files",
    "source_digest"
  ],
  "properties": {
    "schema": {
      "const": "website-bot.assembly-manifest/v2"
    },
    "build_id": {
      "type": "string",
      "minLength": 1
    },
    "client_id": {
      "type": "string",
      "minLength": 1
    },
    "generator_version": {
      "type": "string",
      "minLength": 1
    },
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/file"
      }
    },
    "source_digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "output_dir": {
      "type": "string",
      "minLength": 1
    },
    "template_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "template_digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "$defs": {
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "owner",
        "bytes"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "(^/|(^|/)\\.\\.?(/|$))"
          }
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "owner": {
          "const": "website-bot"
        },
        "bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  },
  "x_l9_meta": {
    "layer": "contract",
    "role": "persisted_schema",
    "status": "active",
    "version": "2.0.0"
  }
}
