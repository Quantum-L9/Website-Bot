{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:quantum-l9:website-bot:assembly-manifest:v1",
  "title": "Website-Bot Assembly Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "buildId",
    "clientId",
    "generatorVersion",
    "routes",
    "files",
    "sourceDigest"
  ],
  "properties": {
    "schema": {
      "const": "website-bot.assembly-manifest/v1"
    },
    "buildId": {
      "type": "string",
      "minLength": 1
    },
    "clientId": {
      "type": "string",
      "minLength": 1
    },
    "generatorVersion": {
      "type": "string",
      "minLength": 1
    },
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/file"
      }
    },
    "sourceDigest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "outputDir": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "owner",
        "bytes"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "(^/|(^|/)\\.\\.?(/|$))"
          }
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "owner": {
          "const": "website-bot"
        },
        "bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
