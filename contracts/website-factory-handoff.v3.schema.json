{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantum-l9.dev/contracts/website-factory-handoff.v3.schema.json",
  "title": "L9 Website Factory to SEO Bot Handoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol",
    "schema_version",
    "contract_id",
    "emitted_at",
    "client",
    "seo",
    "site",
    "proof",
    "integrity"
  ],
  "properties": {
    "protocol": {
      "const": "l9.website-factory.handoff"
    },
    "schema_version": {
      "const": "3.0"
    },
    "contract_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 200
    },
    "emitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "client": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "domain",
        "name",
        "industry"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "domain": {
          "type": "string",
          "minLength": 3
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "industry": {
          "type": "string",
          "minLength": 1
        },
        "city": {
          "type": "string"
        },
        "state": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        }
      }
    },
    "seo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_keywords",
        "competitor_urls"
      ],
      "properties": {
        "target_keywords": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "keyword",
              "priority"
            ],
            "properties": {
              "keyword": {
                "type": "string",
                "minLength": 1
              },
              "priority": {
                "enum": [
                  "critical",
                  "high",
                  "medium",
                  "low"
                ]
              }
            }
          }
        },
        "competitor_urls": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "site": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "deployment",
        "maintenance"
      ],
      "properties": {
        "repository": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "provider",
            "full_name",
            "branch",
            "commit_sha",
            "source_digest",
            "managed_manifest_path",
            "editable_root",
            "page_path_strategy"
          ],
          "properties": {
            "provider": {
              "const": "github"
            },
            "full_name": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
            },
            "repository_id": {
              "type": "string",
              "minLength": 1
            },
            "branch": {
              "type": "string",
              "minLength": 1
            },
            "commit_sha": {
              "type": "string",
              "pattern": "^[a-f0-9]{40}$"
            },
            "source_digest": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "managed_manifest_path": {
              "const": ".l9/generated-manifest.json"
            },
            "editable_root": {
              "const": "src/pages"
            },
            "page_path_strategy": {
              "const": "directory-index-astro"
            }
          }
        },
        "deployment": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "provider",
            "project_id",
            "deployment_id",
            "deployment_url",
            "state",
            "requested_commit_sha",
            "observed_commit_sha"
          ],
          "properties": {
            "provider": {
              "const": "vercel"
            },
            "project_id": {
              "type": "string",
              "minLength": 1
            },
            "deployment_id": {
              "type": "string",
              "minLength": 1
            },
            "deployment_url": {
              "type": "string",
              "format": "uri"
            },
            "state": {
              "const": "READY"
            },
            "requested_commit_sha": {
              "type": "string",
              "pattern": "^[a-f0-9]{40}$"
            },
            "observed_commit_sha": {
              "type": "string",
              "pattern": "^[a-f0-9]{40}$"
            }
          }
        },
        "maintenance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "transport",
            "github_credential_ref",
            "required_paths"
          ],
          "properties": {
            "enabled": {
              "const": true
            },
            "transport": {
              "const": "github-contents-api"
            },
            "github_credential_ref": {
              "type": "string",
              "pattern": "^env://[A-Z][A-Z0-9_]*$"
            },
            "vercel_deploy_hook_ref": {
              "type": "string",
              "pattern": "^env://[A-Z][A-Z0-9_]*$"
            },
            "required_paths": {
              "type": "array",
              "minItems": 2,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
              },
              "allOf": [
                {
                  "contains": {
                    "const": ".l9/generated-manifest.json"
                  },
                  "minContains": 1
                },
                {
                  "contains": {
                    "const": "src/pages/index.astro"
                  },
                  "minContains": 1
                }
              ]
            }
          }
        }
      }
    },
    "proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_id",
        "receipt_status",
        "source_digest",
        "dist_digest",
        "local_build_status",
        "publication_status",
        "deployment_status"
      ],
      "properties": {
        "receipt_id": {
          "type": "string",
          "minLength": 1
        },
        "receipt_status": {
          "const": "succeeded"
        },
        "source_digest": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "dist_digest": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "local_build_status": {
          "const": "passed"
        },
        "publication_status": {
          "const": "passed"
        },
        "deployment_status": {
          "const": "passed"
        }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "payload_digest"
      ],
      "properties": {
        "algorithm": {
          "const": "sha256"
        },
        "payload_digest": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    }
  }
}
